# ── Supabase PostgreSQL ─────────────────────────────────────────────────────
# W panelu: Project Settings → Database → Connection string.
#
# Znak # w haśle MUSI być w URI zakodowany jako %23 (inaczej reszta URL zostanie ucięta).
#
# DATABASE_URL — aplikacja (pooler, zwykle port 6543). Użytkownik: postgres.[project-ref]
DATABASE_URL="postgresql://postgres.[project-ref]:[HASLO_Z_%23_JAK_TRZEBA]@[region].pooler.supabase.com:6543/postgres?sslmode=require"
#
# DIRECT_DATABASE_URL — zalecane: connection „Direct” (db.*:5432, user postgres) do migracji i seeda.
# Jeśli Direct jest z Twojej sieci niedostępny, zobacz MIGRATE_DATABASE_URL albo wklej SQL migracji w Supabase → SQL Editor.
DIRECT_DATABASE_URL="postgresql://postgres:[HASLO]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"
#
# MIGRATE_DATABASE_URL — opcjonalnie: ten sam URL co Direct; używany tylko przez `prisma migrate` / `db push` / `db execute`
# (gdy nie chcesz ustawiać DIRECT_DATABASE_URL na stałe). Aplikacja dalej używa DATABASE_URL.
# MIGRATE_DATABASE_URL="postgresql://postgres:[HASLO]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"
#
# Jeśli `npx prisma db push` zgłasza błąd TLS, spróbuj dopisać do URL migracji: ?sslmode=no-verify (tylko dev).

# Opcjonalnie: wymuś ścisłą weryfikację certyfikatu TLS dla hostów Supabase w runtime (domyślnie wyłączone
# z powodu błędów „self-signed certificate in certificate chain” na części systemów).
# DATABASE_SSL_STRICT=1

# NEXT_PUBLIC_APP_URL — ten sam origin co BETTER_AUTH_URL (klient auth, linki resetu).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="wygeneruj-długi-sekret"
BETTER_AUTH_URL="http://localhost:3000"
# Opcjonalnie dodatkowe originy (CSV) dla CORS / zaufanych żądań.
# BETTER_AUTH_TRUSTED_ORIGINS=

# ── (Opcjonalnie) stare zmienne — nie są już wymagane do tenant scope ────────
# DEFAULT_ORGANIZATION_ID — nieużywane przy sesji (organizacja z rekordu użytkownika).
# APP_USER_ID=

# OCR — lokalnie (Tesseract.js + pdf-parse). Brak kluczy API zewnętrznych.
# Pierwsze uruchomienie pobierze modele językowe (pol, eng) — wymagany internet.
