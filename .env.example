# ── Supabase PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[HASLO]@[region].pooler.supabase.com:6543/postgres?sslmode=require"

# ── Supabase Auth (wymagane w produkcji) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Tylko do skryptu db:create-super-admin (nigdy w frontendzie!)
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# SUPER_ADMIN_EMAIL="admin@example.com"
# SUPER_ADMIN_PASSWORD="SuperAdmin2026!"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Pomoc / wsparcie (mailto w pasku nawigacji)
# NEXT_PUBLIC_SUPPORT_EMAIL="konsultant@twojadomena.pl"

# KRS Open API (Ministerstwo Sprawiedliwości) — tylko serwer (proxy /api/krs/lookup)
# KRS_API_BASE_URL="https://api-krs.ms.gov.pl"
# MF_WL_API_BASE_URL="https://wl-api.mf.gov.pl"
# KRS_API_TIMEOUT_MS=12000

# Dev: pomiń logowanie gdy brak Supabase URL (domyślnie w development)
# AUTH_BYPASS=1

# Dev: wymuś użytkownika bez Supabase Auth
# DEV_USER_ID="seed-admin-example"
# DEV_ORGANIZATION_ID="org_default"

# Cron — audyt subskrypcji (GET /api/cron/subscriptions, Authorization: Bearer …)
# CRON_SECRET="losowy-ciag-znakow"

# OCR
# OCR_LANGUAGES="pol+eng"
# FILE_STORAGE=local

# KSeF (Krajowy System e-Faktur)
# KSEF_ENCRYPTION_KEY="losowy-ciag-min-32-znakow"
# KSEF_API_BASE_URL_TEST="https://api-test.ksef.mf.gov.pl"
# KSEF_API_BASE_URL_PROD="https://api.ksef.mf.gov.pl"
# KSEF_API_TIMEOUT_MS=20000
